# Copy this file to .env.local and fill in your Supabase project credentials.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin users: auth.users (password = bcrypt hash) + public.profiles (role only).
# Never put passwords in .env or in the profiles table. Create users: npm run seed:admin
